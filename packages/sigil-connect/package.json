    "typecheck": "tsc --noEmit"
  },
  "keywords": ["qubic", "wallet", "sigil", "deep-link", "signing"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}

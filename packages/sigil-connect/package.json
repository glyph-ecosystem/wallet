{
  "name": "@sigil/connect",
  "version": "0.1.0",
  "description": "TypeScript SDK for integrating web apps with the Sigil wallet via the Sigil Request Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
